# ── Database ──────────────────────────────────────────────────────────────────
# Option A: full connection URL (takes priority over individual vars below)
# DATABASE_URL=postgresql://texedo:changeme@localhost:5432/texedo_db

# Option B: individual parts (used when DATABASE_URL is not set)
POSTGRES_USER=texedo
POSTGRES_PASSWORD=changeme          # REQUIRED — no default, app refuses to start without it
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=texedo_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for: sliding-window rate limiting on /api/latex and compiled PDF cache.
# Defaults to localhost:6379 if not set (suitable for local dev without Docker).
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379                     # host port exposed by docker-compose

# ── MinIO / S3-compatible object storage ──────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ROOT_USER=texedo              # REQUIRED
MINIO_ROOT_PASSWORD=changeme        # REQUIRED — no default
MINIO_BUCKET=texedo

# ── Security ──────────────────────────────────────────────────────────────────
# Optional. When set, every /api/* request must include:
#   Authorization: Bearer <value>
# Leave unset for fully local/open deployments.
# TEXEDO_API_SECRET=

# CORS: restrict which origin may call the API.
# Leave unset for same-origin only (recommended for single-domain deploys).
# TEXEDO_ALLOWED_ORIGIN=https://texedo.example.com

# ── Next.js ───────────────────────────────────────────────────────────────────
NODE_ENV=development
